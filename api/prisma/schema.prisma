generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum FinanceStatus {
  PROCESSADO
  EM_REVISAO
  EXCECAO
  CONCILIADO
  PENDENTE
}

enum Severity {
  ALTA
  MEDIA
  BAIXA
}

enum LogStatus {
  OK
  WARN
  ERR
}

enum AutomationStatus {
  ACTIVE
  PAUSED
}

enum IntegrationStatus {
  CONNECTED
  AVAILABLE
}

model Company {
  id                        String                       @id @default(cuid())
  name                      String
  slug                      String                       @unique
  domain                    String
  companiesCount            Int                          @default(1)
  country                   String                       @default("BR")
  aiCycleLabel              String                       @default("ciclo #2.184")
  aiUptime                  Float                        @default(99.98)
  latencyMs                 Int                          @default(142)
  integrationsHealthy       Int                          @default(8)
  integrationsTotal         Int                          @default(8)
  timeSavedHours            Int                          @default(284)
  operationalSavings        Decimal                      @db.Decimal(12, 2)
  monthlyOperations         Int                          @default(8241)
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  users                     User[]
  clients                   Client[]
  suppliers                 Supplier[]
  accountsPayable           AccountPayable[]
  accountsReceivable        AccountReceivable[]
  operations                Operation[]
  reconciliationItems       ReconciliationItem[]
  exceptionItems            ExceptionItem[]
  aiLogs                    AiLog[]
  automations               Automation[]
  flows                     Flow[]
  reports                   Report[]
  integrations              Integration[]
  cashflowPoints            CashflowPoint[]
  expenseCategories         ExpenseCategory[]
  dailyReconciliationPoints DailyReconciliationPoint[]
  performancePoints         PerformancePoint[]
  dreEntries                DreEntry[]
  insights                  Insight[]
  auditLogs                 AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
}

model Client {
  id            String              @id @default(cuid())
  name          String
  segment       String
  annualRevenue Decimal             @db.Decimal(14, 2)
  status        String
  sinceYear     Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  companyId     String
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  receivables   AccountReceivable[]
}

model Supplier {
  id              String           @id @default(cuid())
  name            String
  cnpj            String?
  category        String
  yearlySpend     Decimal          @db.Decimal(14, 2)
  lastTransaction String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payables        AccountPayable[]
  operations      Operation[]
}

model AccountPayable {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(14, 2)
  dueDate     DateTime
  category    String
  status      FinanceStatus
  confidence  Float
  source      String
  assignee    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  companyId   String
  supplierId  String?
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
}

model AccountReceivable {
  id         String        @id @default(cuid())
  amount     Decimal       @db.Decimal(14, 2)
  dueDate    DateTime
  status     FinanceStatus
  source     String
  channel    String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  companyId  String
  clientId   String?
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client     Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model Operation {
  id          String        @id @default(cuid())
  reference   String        @unique
  amount      Decimal       @db.Decimal(14, 2)
  dueDate     DateTime
  category    String
  status      FinanceStatus
  source      String
  confidence  Float
  assignee    String
  direction   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  companyId   String
  supplierId  String?
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
}

model ReconciliationItem {
  id              String    @id @default(cuid())
  code            String    @unique
  bankDate        DateTime
  bankDescription String
  bankValue       Decimal   @db.Decimal(14, 2)
  bookDate        DateTime?
  bookDescription String
  bookValue       Decimal   @db.Decimal(14, 2)
  matchScore      Float
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ExceptionItem {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  description String
  suggestion  String
  confidence  Float
  severity    Severity
  status      String    @default("OPEN")
  timeLabel   String
  timeline    Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AiLog {
  id             String    @id @default(cuid())
  occurredAt     DateTime
  input          String
  action         String
  confidence     Float
  status         LogStatus
  parsedPayload  Json
  justification  String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String           @id @default(cuid())
  title       String
  description String
  runs        Int
  accuracy    Float
  status      AutomationStatus
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Flow {
  id          String           @id @default(cuid())
  name        String
  description String
  runs        Int
  status      AutomationStatus
  steps       Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  name        String
  description String
  updatedLabel String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String            @id @default(cuid())
  name        String
  description String
  status      IntegrationStatus
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CashflowPoint {
  id        String   @id @default(cuid())
  monthKey  Int
  month     String
  entrada   Decimal  @db.Decimal(14, 2)
  saida     Decimal  @db.Decimal(14, 2)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  value     Int
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model DailyReconciliationPoint {
  id        String   @id @default(cuid())
  day       Int
  auto      Int
  manual    Int
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PerformancePoint {
  id        String   @id @default(cuid())
  day       Int
  accuracy  Float
  ops       Int
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model DreEntry {
  id        String   @id @default(cuid())
  label     String
  value     Decimal  @db.Decimal(14, 2)
  type      String
  bold      Boolean  @default(false)
  highlight Boolean  @default(false)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Insight {
  id          String   @id @default(cuid())
  tone        String
  title       String
  description String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  resource   String
  details    Json
  createdAt  DateTime @default(now())
  companyId  String
  userId     String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

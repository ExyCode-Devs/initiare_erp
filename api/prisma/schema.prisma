generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum FinanceStatus {
  PROCESSADO
  EM_REVISAO
  EXCECAO
  CONCILIADO
  PENDENTE
}

enum Severity {
  ALTA
  MEDIA
  BAIXA
}

enum LogStatus {
  OK
  WARN
  ERR
}

enum AutomationStatus {
  ACTIVE
  PAUSED
}

enum IntegrationStatus {
  CONNECTED
  AVAILABLE
}

enum InboxStatus {
  RECEBIDO
  PROCESSANDO
  PROCESSADO
  AGUARDANDO_VALIDACAO
  APROVADO
  REJEITADO
  ERRO
}

enum AttachmentStatus {
  PENDENTE
  EXTRAIDO
  ERRO
}

enum DraftStatus {
  PENDENTE_REVISAO
  APROVADO
  REJEITADO
}

enum ConfidenceBand {
  ALTA
  MEDIA
  BAIXA
}

enum ChangelogCategory {
  NOVA_FUNCIONALIDADE
  MELHORIA
  CORRECAO
  INTEGRACAO
  IA
  DASHBOARD
}

enum ChangelogStatus {
  RASCUNHO
  PUBLICADO
}

enum ExtractionRunStatus {
  PENDENTE
  SUCESSO
  ERRO
}

enum JobRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum FinancialDirection {
  CONTA_PAGAR
  CONTA_RECEBER
}

enum ReviewAction {
  EDIT
  APPROVE
  REJECT
}

enum AiEventOriginType {
  ACTIVE_ACTIONS
  INTERNAL
}

enum AiEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum AiGatewayRunStatus {
  PENDENTE
  SUCESSO
  ERRO
}

enum ErpProvider {
  OMIE
  ASAAS
}

enum ErpEnvironment {
  HOMOLOG
  SANDBOX
  PRODUCTION
}

enum ErpHealthStatus {
  UNKNOWN
  HEALTHY
  ERROR
}

enum ErpSyncEntityType {
  CLIENT
  SUPPLIER
  CATEGORY
  CURRENT_ACCOUNT
  ACCOUNT_PAYABLE
  ACCOUNT_RECEIVABLE
  CHARGE
  PAYMENT_RECEIPT
  FEE
}

enum ErpSyncStatus {
  PENDING
  SUCCESS
  ERROR
  BLOCKED
}

enum ErpOperationStatus {
  SUCCESS
  ERROR
}

model Company {
  id                        String                       @id @default(cuid())
  name                      String
  slug                      String                       @unique
  domain                    String
  companiesCount            Int                          @default(1)
  country                   String                       @default("BR")
  aiCycleLabel              String                       @default("ciclo #2.184")
  aiUptime                  Float                        @default(99.98)
  latencyMs                 Int                          @default(142)
  integrationsHealthy       Int                          @default(8)
  integrationsTotal         Int                          @default(8)
  timeSavedHours            Int                          @default(284)
  operationalSavings        Decimal                      @db.Decimal(12, 2)
  monthlyOperations         Int                          @default(8241)
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  users                     User[]
  clients                   Client[]
  suppliers                 Supplier[]
  accountsPayable           AccountPayable[]
  accountsReceivable        AccountReceivable[]
  operations                Operation[]
  reconciliationItems       ReconciliationItem[]
  exceptionItems            ExceptionItem[]
  aiLogs                    AiLog[]
  automations               Automation[]
  flows                     Flow[]
  reports                   Report[]
  integrations              Integration[]
  cashflowPoints            CashflowPoint[]
  expenseCategories         ExpenseCategory[]
  dailyReconciliationPoints DailyReconciliationPoint[]
  performancePoints         PerformancePoint[]
  dreEntries                DreEntry[]
  insights                  Insight[]
  auditLogs                 AuditLog[]
  aiEventSources            AiEventSource[]
  aiGatewayRuns             AiGatewayRun[]
  mailboxAccounts           MailboxAccount[]
  inboundEmails             InboundEmail[]
  emailAttachments          EmailAttachment[]
  n8nExtractionRuns         N8nExtractionRun[]
  financialDrafts           FinancialDraft[]
  financialDraftReviews     FinancialDraftReview[]
  processingJobRuns         ProcessingJobRun[]
  changelogEntries          ChangelogEntry[]
  changelogReads            ChangelogRead[]
  erpConnections            ErpConnection[]
  erpSyncRecords            ErpSyncRecord[]
  erpRequestLogs            ErpRequestLog[]
  erpWebhookEvents          ErpWebhookEvent[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  financialDraftReviews FinancialDraftReview[]
  authoredChangelogEntries ChangelogEntry[]
  changelogReads ChangelogRead[]
  triggeredErpRequestLogs ErpRequestLog[] @relation("ErpRequestTriggeredBy")
  triggeredErpWebhookEvents ErpWebhookEvent[] @relation("ErpWebhookTriggeredBy")
}

model MailboxAccount {
  id             String   @id @default(cuid())
  name           String
  host           String
  port           Int
  tls            Boolean  @default(true)
  username       String
  passwordCipher String
  fromFilter     String?
  active         Boolean  @default(true)
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inboundEmails  InboundEmail[]
  jobRuns        ProcessingJobRun[]

  @@index([companyId, active])
}

model InboundEmail {
  id                String            @id @default(cuid())
  externalMessageId String?           @unique
  dedupeHash        String            @unique
  sender            String
  replyTo           String?
  toRecipients      Json
  ccRecipients      Json?
  bccRecipients     Json?
  subject           String
  bodyText          String            @db.Text
  bodyHtml          String?           @db.Text
  rawHeaders        Json
  originalEmlPath   String
  receivedAt        DateTime
  status            InboxStatus       @default(RECEBIDO)
  processingError   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  companyId         String
  mailboxId         String
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mailbox           MailboxAccount    @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  attachments       EmailAttachment[]
  extractionRuns    N8nExtractionRun[]
  financialDrafts   FinancialDraft[]

  @@index([companyId, status, receivedAt])
  @@index([mailboxId, receivedAt])
}

model EmailAttachment {
  id              String           @id @default(cuid())
  originalName    String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  checksum        String
  extractedText   String?          @db.Text
  extractionMeta  Json?
  status          AttachmentStatus @default(PENDENTE)
  processingError String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companyId       String
  emailId         String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email           InboundEmail     @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([emailId])
}

model N8nExtractionRun {
  id               String              @id @default(cuid())
  provider         String              @default("n8n")
  workflowId       String?
  requestPayload   Json
  rawResponse      String?             @db.Text
  parsedResponse   Json?
  status           ExtractionRunStatus @default(PENDENTE)
  errorMessage     String?
  durationMs       Int?
  startedAt        DateTime            @default(now())
  completedAt      DateTime?
  companyId        String
  emailId          String
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email            InboundEmail        @relation(fields: [emailId], references: [id], onDelete: Cascade)
  financialDraft   FinancialDraft?

  @@index([companyId, status, startedAt])
  @@index([emailId])
}

model FinancialDraft {
  id                   String             @id @default(cuid())
  direction            FinancialDirection
  partyName            String
  cpfCnpj              String?
  amount               Decimal?           @db.Decimal(14, 2)
  dueDate              DateTime?
  competence           String?
  description          String             @db.Text
  suggestedCategory    String?
  finalCategory        String?
  paymentMethod        String?
  bankData             Json?
  notes                String?            @db.Text
  evidence             Json?
  rawPayload           Json
  confidenceScore      Float
  confidenceBand       ConfidenceBand
  status               DraftStatus        @default(PENDENTE_REVISAO)
  sourceLabel          String             @default("AI event")
  rejectionReason      String?
  resultingResourceType String?
  resultingResourceId  String?
  reviewedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  companyId            String
  sourceEmailId        String?
  extractionRunId      String?            @unique
  sourceEventId        String?
  aiRunId              String?            @unique
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceEmail          InboundEmail?      @relation(fields: [sourceEmailId], references: [id], onDelete: Cascade)
  extractionRun        N8nExtractionRun?  @relation(fields: [extractionRunId], references: [id], onDelete: SetNull)
  sourceEvent          AiEventSource?     @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)
  aiRun                AiGatewayRun?      @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  reviews              FinancialDraftReview[]
  erpSyncRecords       ErpSyncRecord[]
  erpRequestLogs       ErpRequestLog[]

  @@index([companyId, status, confidenceBand])
  @@index([sourceEmailId])
  @@index([sourceEventId])
}

model FinancialDraftReview {
  id          String       @id @default(cuid())
  action      ReviewAction
  note        String?
  fieldDelta  Json?
  createdAt   DateTime     @default(now())
  companyId   String
  draftId     String
  userId      String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  draft       FinancialDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([draftId])
}

model ProcessingJobRun {
  id             String       @id @default(cuid())
  runType        String
  status         JobRunStatus @default(RUNNING)
  fetchedCount   Int          @default(0)
  processedCount Int          @default(0)
  errorCount     Int          @default(0)
  summary        Json?
  errorMessage   String?
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  companyId      String
  mailboxId      String?
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mailbox        MailboxAccount? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@index([companyId, status, startedAt])
  @@index([mailboxId])
}

model ChangelogEntry {
  id          String            @id @default(cuid())
  title       String
  description String           @db.Text
  version     String
  category    ChangelogCategory
  status      ChangelogStatus   @default(RASCUNHO)
  imageUrl    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  publishedAt DateTime?
  companyId   String
  authorId    String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reads       ChangelogRead[]

  @@index([companyId, status, publishedAt])
}

model ChangelogRead {
  id         String         @id @default(cuid())
  firstSeenAt DateTime      @default(now())
  readAt     DateTime?
  createdAt  DateTime       @default(now())
  companyId  String
  entryId    String
  userId     String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entry      ChangelogEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([companyId, userId])
}

model Client {
  id            String              @id @default(cuid())
  name          String
  segment       String
  annualRevenue Decimal             @db.Decimal(14, 2)
  status        String
  sinceYear     Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  companyId     String
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  receivables   AccountReceivable[]
}

model Supplier {
  id              String           @id @default(cuid())
  name            String
  cnpj            String?
  category        String
  yearlySpend     Decimal          @db.Decimal(14, 2)
  lastTransaction String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payables        AccountPayable[]
  operations      Operation[]
}

model AccountPayable {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(14, 2)
  dueDate     DateTime
  category    String
  status      FinanceStatus
  confidence  Float
  source      String
  assignee    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  companyId   String
  supplierId  String?
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
}

model AccountReceivable {
  id         String        @id @default(cuid())
  amount     Decimal       @db.Decimal(14, 2)
  dueDate    DateTime
  status     FinanceStatus
  source     String
  channel    String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  companyId  String
  clientId   String?
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client     Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model Operation {
  id          String        @id @default(cuid())
  reference   String        @unique
  amount      Decimal       @db.Decimal(14, 2)
  dueDate     DateTime
  category    String
  status      FinanceStatus
  source      String
  confidence  Float
  assignee    String
  direction   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  companyId   String
  supplierId  String?
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
}

model ReconciliationItem {
  id              String    @id @default(cuid())
  code            String    @unique
  bankDate        DateTime
  bankDescription String
  bankValue       Decimal   @db.Decimal(14, 2)
  bookDate        DateTime?
  bookDescription String
  bookValue       Decimal   @db.Decimal(14, 2)
  matchScore      Float
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ExceptionItem {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  description String
  suggestion  String
  confidence  Float
  severity    Severity
  status      String    @default("OPEN")
  timeLabel   String
  timeline    Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AiLog {
  id             String    @id @default(cuid())
  occurredAt     DateTime
  input          String
  action         String
  confidence     Float
  status         LogStatus
  parsedPayload  Json
  justification  String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String           @id @default(cuid())
  title       String
  description String
  runs        Int
  accuracy    Float
  status      AutomationStatus
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Flow {
  id          String           @id @default(cuid())
  name        String
  description String
  runs        Int
  status      AutomationStatus
  steps       Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  name        String
  description String
  updatedLabel String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String            @id @default(cuid())
  name        String
  description String
  status      IntegrationStatus
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CashflowPoint {
  id        String   @id @default(cuid())
  monthKey  Int
  month     String
  entrada   Decimal  @db.Decimal(14, 2)
  saida     Decimal  @db.Decimal(14, 2)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  value     Int
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model DailyReconciliationPoint {
  id        String   @id @default(cuid())
  day       Int
  auto      Int
  manual    Int
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PerformancePoint {
  id        String   @id @default(cuid())
  day       Int
  accuracy  Float
  ops       Int
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model DreEntry {
  id        String   @id @default(cuid())
  label     String
  value     Decimal  @db.Decimal(14, 2)
  type      String
  bold      Boolean  @default(false)
  highlight Boolean  @default(false)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Insight {
  id          String   @id @default(cuid())
  tone        String
  title       String
  description String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  resource   String
  details    Json
  createdAt  DateTime @default(now())
  companyId  String
  userId     String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ErpConnection {
  id                   String          @id @default(cuid())
  provider             ErpProvider
  environment          ErpEnvironment
  appKeyCipher         String?
  appSecretCipher      String?
  webhookAuthTokenCipher String?
  baseUrl              String
  enabled              Boolean         @default(false)
  lastSyncAt           DateTime?
  lastHealthcheckAt    DateTime?
  lastHealthcheckStatus ErpHealthStatus @default(UNKNOWN)
  lastError            String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  companyId            String
  company              Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  syncRecords          ErpSyncRecord[]
  requestLogs          ErpRequestLog[]
  webhookEvents        ErpWebhookEvent[]

  @@unique([companyId, provider, environment])
  @@index([companyId, provider, enabled])
}

model ErpSyncRecord {
  id              String           @id @default(cuid())
  provider        ErpProvider
  environment     ErpEnvironment
  entityType      ErpSyncEntityType
  internalId      String
  externalId      String?
  status          ErpSyncStatus    @default(PENDING)
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  syncedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companyId       String
  connectionId    String
  draftId         String?
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection      ErpConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  draft           FinancialDraft?  @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@unique([companyId, provider, environment, entityType, internalId])
  @@index([companyId, status, updatedAt])
  @@index([draftId, updatedAt])
}

model ErpRequestLog {
  id                String             @id @default(cuid())
  method            String
  endpoint          String
  requestBody       Json?
  responseBody      Json?
  httpStatus        Int?
  operationStatus   ErpOperationStatus
  friendlyError     String?
  technicalError    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companyId         String
  connectionId      String
  draftId           String?
  triggeredByUserId String?
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection        ErpConnection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  draft             FinancialDraft?    @relation(fields: [draftId], references: [id], onDelete: SetNull)
  triggeredByUser   User?              @relation("ErpRequestTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([draftId, createdAt])
  @@index([connectionId, createdAt])
}

model ErpWebhookEvent {
  id                String          @id @default(cuid())
  provider          ErpProvider
  environment       ErpEnvironment
  externalEventId   String
  eventType         String
  headers           Json?
  payload           Json
  status            ErpSyncStatus   @default(PENDING)
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  companyId         String
  connectionId      String?
  triggeredByUserId String?
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection        ErpConnection?  @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  triggeredByUser   User?           @relation("ErpWebhookTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@unique([companyId, provider, environment, externalEventId])
  @@index([companyId, provider, createdAt])
  @@index([connectionId, createdAt])
}

model AiEventSource {
  id              String            @id @default(cuid())
  eventId         String
  originType      AiEventOriginType
  channel         String
  sender          String?
  subject         String?
  summary         String?           @db.Text
  attachmentsMeta Json?
  rawPayload      Json
  receivedAt      DateTime
  status          AiEventStatus     @default(RECEIVED)
  processingError String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiRuns          AiGatewayRun[]
  financialDrafts FinancialDraft[]

  @@unique([companyId, eventId])
  @@index([companyId, receivedAt])
  @@index([companyId, status, createdAt])
}

model AiGatewayRun {
  id             String             @id @default(cuid())
  provider       String
  requestPayload Json
  rawResponse    String?            @db.Text
  parsedResponse Json?
  status         AiGatewayRunStatus @default(PENDENTE)
  errorMessage   String?
  durationMs     Int?
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  companyId      String
  eventSourceId  String
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  eventSource    AiEventSource      @relation(fields: [eventSourceId], references: [id], onDelete: Cascade)
  financialDraft FinancialDraft?

  @@index([companyId, status, startedAt])
  @@index([eventSourceId])
}

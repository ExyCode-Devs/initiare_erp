{
  "name": "initiare_erp-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-with-root-env.mjs tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test:serve": "node scripts/run-with-root-env.mjs tsx src/index.ts",
    "bootstrap": "node scripts/run-with-root-env.mjs tsx prisma/bootstrap.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node scripts/run-with-root-env.mjs prisma migrate deploy",
    "prisma:seed": "node scripts/run-with-root-env.mjs tsx prisma/bootstrap.ts",
    "prisma:seed:demo": "node scripts/run-with-root-env.mjs tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/bootstrap.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^6.10.1",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.0",
    "imapflow": "^1.3.5",
    "mailparser": "^3.9.9",
    "pdf-parse": "^2.4.5",
    "prom-client": "^15.1.3",
    "tanstack_start_ts": "file:..",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.0.10",
    "pino-pretty": "^13.1.2",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
